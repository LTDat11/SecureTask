@model RegisterRequest

@{
    ViewData["Title"] = "TaskMaster - Đăng ký";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    body {
        font-family: 'Inter', sans-serif;
    }
</style>

<div class="min-h-[calc(100vh-64px)] flex flex-col md:flex-row bg-white">
    <div class="flex-1 flex items-center justify-center p-8 lg:p-16 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-72 h-72 bg-indigo-600 rounded-full blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-72 h-72 bg-violet-600 rounded-full blur-[120px]"></div>
        </div>

        <div class="max-w-md relative z-10">
            <h1 class="text-6xl font-extrabold text-slate-900 leading-[1.1] tracking-tight">
                Quản lý Task <br />
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-purple-600 to-violet-600">
                    không giới hạn.
                </span>
            </h1>
            <p class="mt-6 text-slate-500 text-lg leading-relaxed">
                Tối ưu hóa quy trình làm việc. Đừng chỉ quản lý công việc, hãy làm chủ thời gian của bạn.
            </p>

            <div class="mt-10 flex gap-6">
                <div class="flex -space-x-2">
                    <img class="inline-block h-8 w-8 rounded-full ring-2 ring-white"
                         src="https://ui-avatars.com/api/?name=User+1&background=random" alt="">
                    <img class="inline-block h-8 w-8 rounded-full ring-2 ring-white"
                         src="https://ui-avatars.com/api/?name=User+2&background=random" alt="">
                    <img class="inline-block h-8 w-8 rounded-full ring-2 ring-white"
                         src="https://ui-avatars.com/api/?name=User+3&background=random" alt="">
                </div>
                <p class="text-sm text-slate-400 flex items-center font-medium">Tham gia cùng +1,200 người dùng</p>
            </div>
        </div>
    </div>

    <div class="flex-1 bg-slate-50/50 flex items-center justify-center p-6 lg:p-12 relative">
        <div
            class="w-full max-w-md bg-white rounded-[2rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.08)] border border-slate-200/60 overflow-hidden backdrop-blur-sm">

            <div class="p-8 pt-6 space-y-6 flex-shrink-0">
                <div class="text-center space-y-1">
                    <h2 class="text-2xl font-bold text-slate-800">Tham gia ngay</h2>
                    <p class="text-slate-400 text-sm">Chỉ mất 30 giây để bắt đầu.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="p-4 mb-4 bg-red-50 border border-red-200 rounded-2xl">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <p class="text-red-600 text-sm">@error.ErrorMessage</p>
                            }
                        }
                    </div>
                }

                <form asp-action="Register" method="post" class="space-y-4">
                    <div class="group">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Tên
                            đăng nhập</label>
                            <div class="relative">
                                <span
                                    class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                                <input asp-for="Username" type="text"
                                       class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white outline-none transition-all"
                                       placeholder="username123">
                                </div>
                                <span asp-validation-for="Username" class="text-red-500 text-xs mt-1 block"></span>
                            </div>

                            <div class="group">
                                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Mật
                                    khẩu</label>
                                    <div class="relative">
                                        <span
                                            class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path
                                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                            </svg>
                                        </span>
                                        <input asp-for="Password" type="password"
                                               class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white outline-none transition-all"
                                               placeholder="••••••••">
                                        </div>
                                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                                    </div>

                                    <div class="group">
                                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Xác
                                            nhận mật khẩu</label>
                                            <div class="relative">
                                                <span
                                                    class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path
                                                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                    </svg>
                                                </span>
                                                <input asp-for="ConfirmPassword" type="password"
                                                       class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 focus:bg-white outline-none transition-all"
                                                       placeholder="••••••••">
                                                </div>
                                                <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
                                            </div>

                                            <button type="submit"
                                                    class="w-full py-4 bg-slate-900 hover:bg-black text-white rounded-2xl font-bold shadow-xl shadow-slate-200 transition-all active:scale-[0.97] hover:-translate-y-0.5">
                                                Đăng ký
                                            </button>
                                        </form>

                                        <div class="relative">
                                            <div class="absolute inset-0 flex items-center">
                                                <div class="w-full border-t border-slate-200"></div>
                                            </div>
                                            <div class="relative flex justify-center text-sm">
                                                <span class="px-2 bg-white text-slate-500">Hoặc</span>
                                            </div>
                                        </div>

                                        <a asp-action="Login"
                                               class="block w-full py-3 text-center text-slate-600 font-bold rounded-2xl border-2 border-slate-200 hover:bg-slate-50 transition-all">
                                            Đã có tài khoản? Đăng nhập
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>