<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        scroll-behavior: smooth;
        }
    </style>
</head>
<body class="bg-white text-slate-900 antialiased">
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7">
                            </path>
                        </svg>
                    </div>
                    <span class="font-bold text-xl tracking-tight text-slate-900">TaskMaster</span>
                </div>
                <div class="hidden md:flex items-center gap-8">
                    @* <a href="#" class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors">Tính năng</a>
                    <a href="#" class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors">Bảng giá</a>
                    <a href="#" class="px-4 py-2 bg-slate-900 text-white text-sm font-bold rounded-xl hover:bg-slate-800 transition-all">Tải App</a> *@
                </div>
            </div>
        </div>
    </nav>

    <main role="main" class="pt-16">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)

    <div id="toast-container" class="fixed bottom-5 right-5 z-[100] flex flex-col gap-3"></div>

    <script>
        // Hàm thông báo dùng chung toàn hệ thống
        window.showToast = function (message, type = 'info') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');

        const colors = {
        info: 'bg-white border-slate-200 text-slate-800',
        success: 'bg-emerald-50 border-emerald-100 text-emerald-800',
        warning: 'bg-amber-50 border-amber-100 text-amber-800'
        };

        // QUAN TRỌNG: Phải có 'group' và 'relative' ở đây
        toast.className = `group relative flex items-start gap-3 px-5 py-4 rounded-2xl shadow-2xl border ${colors[type]} 
        transition-all duration-500 transform translate-y-10 opacity-0 min-w-[320px] max-w-[400px]`;

        toast.innerHTML = `
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 mt-0.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>

            <div class="flex-1 pr-6">
                <p class="text-sm font-bold tracking-tight text-slate-900">Thông báo</p>
                <p class="text-xs opacity-70 leading-relaxed mt-0.5 font-medium">${message}</p>
            </div>

            <button class="close-btn absolute top-3 right-3 p-1.5 rounded-xl text-slate-400 hover:text-red-500 hover:bg-red-50 transition-all opacity-0 group-hover:opacity-100">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        `;

        container.appendChild(toast);

        const dismissToast = () => {
            toast.classList.add('opacity-0', 'scale-95', '-translate-y-2');
            setTimeout(() => toast.remove(), 500);
        };

        // Gán sự kiện click cho nút X
        toast.querySelector('.close-btn').onclick = (e) => {
            e.stopPropagation();
            dismissToast();
        };

        // Animation hiện lên
        setTimeout(() => {
            toast.classList.remove('translate-y-10', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
        }, 100);

        // Tự động đóng sau 4 giây
        const autoDismiss = setTimeout(dismissToast, 4000);

        // Dừng tự động đóng nếu người dùng đã click đóng tay
        toast.querySelector('.close-btn').addEventListener('click', () => {
            clearTimeout(autoDismiss);
        });
        };
    </script>
</body>

</html>