@using SecureTaskWeb.Models;
@using SecureTaskWeb.Middlewares;

@{
    ViewData["Title"] = "TaskMaster - Dashboard";
    var userSession = Context.Session.Get<UserSession>("UserSession");
    DateTime tokenExpiry = (ViewData["TokenExpiry"] as DateTime?) ?? DateTime.UtcNow.AddHours(1);
    double minutesUntilExpiry = (tokenExpiry - DateTime.UtcNow).TotalMinutes;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    body { font-family: 'Inter', sans-serif; }
    .sidebar-item {
        transition: all 0.3s ease;
    }
    .sidebar-item:hover {
        background-color: rgba(99, 102, 241, 0.1);
        border-left: 3px solid rgb(99, 102, 241);
        padding-left: calc(1.5rem - 3px);
    }
</style>

<div class="min-h-screen flex bg-slate-50">
    <!-- Left Sidebar -->
    <aside class="w-64 bg-white border-r border-slate-200 shadow-sm">
        <div class="p-6 border-b border-slate-200">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-indigo-600 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
                <div>
                    <h1 class="font-bold text-lg text-slate-900">TaskMaster</h1>
                </div>
            </div>
        </div>

        <!-- User Info -->
        <div class="p-6 border-b border-slate-200">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600 font-bold">
                    @(userSession?.Username?.FirstOrDefault() ?? 'U')
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-slate-900 truncate">@userSession?.Username</p>
                    <p class="text-xs text-slate-500">@userSession?.Role</p>
                </div>
            </div>
        </div>

        <!-- Token Expiry Warning -->
        @if (minutesUntilExpiry < 5 && minutesUntilExpiry > 0)
        {
            <div class="m-4 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
                <p class="text-xs font-semibold text-yellow-800">
                    ⚠️ Token sẽ hết hạn trong 
                    @if (minutesUntilExpiry < 1)
                    {
                        <span>dưới 1 phút</span>
                    }
                    else
                    {
                        <span>@Math.Round(minutesUntilExpiry) phút</span>
                    }
                </p>
            </div>
        }

        <!-- Menu Items -->
        <nav class="p-4 space-y-2">
            <a href="#" class="sidebar-item flex items-center gap-3 px-4 py-3 text-slate-700 hover:text-indigo-600 font-medium rounded-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 16l4-4m0 0l4 4m-4-4V5"></path>
                </svg>
                Dashboard
            </a>
            
            <a href="#" class="sidebar-item flex items-center gap-3 px-4 py-3 text-slate-700 hover:text-indigo-600 font-medium rounded-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
                Công việc
            </a>

            <a href="#" class="sidebar-item flex items-center gap-3 px-4 py-3 text-slate-700 hover:text-indigo-600 font-medium rounded-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 18v2m0-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2"></path>
                </svg>
                Cài đặt
            </a>
        </nav>

        <!-- Logout Button -->
        <div class="p-4 border-t border-slate-200 mt-auto">
            <button onclick="confirmLogout()" class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-red-50 hover:bg-red-100 text-red-600 font-semibold rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                Đăng xuất
            </button>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-8">
        <!-- Header -->
        <div class="mb-8">
            <h2 class="text-3xl font-bold text-slate-900">Chào mừng, @userSession?.Username!</h2>
            <p class="text-slate-600 mt-2">Quản lý công việc của bạn một cách hiệu quả</p>
        </div>

        <!-- Welcome Card -->
        <div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl p-8 text-white mb-8 shadow-lg">
            <h3 class="text-2xl font-bold mb-2">Bắt đầu làm việc</h3>
            <p class="text-indigo-100 mb-6">Đây là trang chủ của bạn. Bạn có thể quản lý các công việc và tổ chức công việc của mình ở đây.</p>
            <button onclick="alert('Tính năng sẽ được bổ sung sớm')" class="px-6 py-3 bg-white text-indigo-600 font-bold rounded-lg hover:bg-indigo-50 transition-colors">
                Tạo công việc mới
            </button>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-slate-600 text-sm font-medium">Tổng công việc</p>
                        <p class="text-3xl font-bold text-slate-900 mt-2">0</p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                        <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-slate-600 text-sm font-medium">Hoàn thành</p>
                        <p class="text-3xl font-bold text-slate-900 mt-2">0</p>
                    </div>
                    <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                        <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-slate-600 text-sm font-medium">Đang xử lý</p>
                        <p class="text-3xl font-bold text-slate-900 mt-2">0</p>
                    </div>
                    <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
                        <svg class="w-6 h-6 text-orange-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM7 9a1 1 0 100-2 1 1 0 000 2zm6 0a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Logout Confirmation Modal -->
<div id="logoutModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-xl p-8 max-w-sm mx-4">
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Xác nhận đăng xuất</h3>
        <p class="text-slate-600 mb-8">Bạn có chắc chắn muốn đăng xuất khỏi ứng dụng không?</p>
        <div class="flex gap-4">
            <button onclick="closeLogoutModal()" class="flex-1 px-4 py-3 text-slate-600 border border-slate-200 rounded-lg hover:bg-slate-50 font-semibold transition-colors">
                Hủy
            </button>
            <form action="@Url.Action("Logout", "Auth")" method="get" class="flex-1">
                <button type="submit" class="w-full px-4 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 font-semibold transition-colors">
                    Xác nhận
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function confirmLogout() {
        document.getElementById('logoutModal').classList.remove('hidden');
    }

    function closeLogoutModal() {
        document.getElementById('logoutModal').classList.add('hidden');
    }

    // Auto-refresh token status every minute
    setInterval(() => {
        // You can add auto-refresh token logic here if needed
        console.log('Token expiry check');
    }, 60000);

    // Close modal when clicking outside
    document.getElementById('logoutModal')?.addEventListener('click', function(e) {
        if(e.target === this) {
            closeLogoutModal();
        }
    });
</script>